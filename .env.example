# ============================================================
# AgentHub - 环境变量配置模板
# 使用方式：复制本文件为 .env，填入真实 key
#   cp .env.example .env
# ============================================================

# ===== 后端 Coder agent: GLM（智谱）=====
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5.1

# ===== 产品经理 agent: Kimi（月之暗面）=====
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-for-coding

# ===== QA 验收 agent: DeepSeek =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ===== 前端 Coder agent: MiniMax =====
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.1

# ===== 飞书机器人配置 =====
# 请将真实值填入 .env，不要直接修改本模板

# PM 机器人
FEISHU_PM_APPID=your_feishu_pm_appid
FEISHU_PM_SECRET=your_feishu_pm_secret
FEISHU_PM_VERIFICATION_TOKEN=
FEISHU_PM_ENCRYPT_KEY=

# QA 机器人
FEISHU_QA_APPID=your_feishu_qa_appid
FEISHU_QA_SECRET=your_feishu_qa_secret
FEISHU_QA_VERIFICATION_TOKEN=
FEISHU_QA_ENCRYPT_KEY=

# 前端机器人
FEISHU_FE_APPID=your_feishu_fe_appid
FEISHU_FE_SECRET=your_feishu_fe_secret
FEISHU_FE_VERIFICATION_TOKEN=
FEISHU_FE_ENCRYPT_KEY=

# 后端机器人
FEISHU_BE_APPID=your_feishu_be_appid
FEISHU_BE_SECRET=your_feishu_be_secret
FEISHU_BE_VERIFICATION_TOKEN=
FEISHU_BE_ENCRYPT_KEY=

# Webhook 服务端口
FEISHU_WEBHOOK_PORT=8000
